# =============================================================================
# DriftWatch — Environment Configuration
# Copy this file to .env and fill in your values.
# =============================================================================

# -- Core --
SECRET_KEY=change-me-to-a-random-64-char-string
ENVIRONMENT=development
LOG_LEVEL=info

# -- Database --
DATABASE_URL=postgresql+asyncpg://driftwatch:driftwatch@db:5432/driftwatch
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# -- Redis --
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# -- API --
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000

# -- LLM Providers --
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GOOGLE_AI_API_KEY=your-google-ai-key

# -- Alerting --
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url
PAGERDUTY_ROUTING_KEY=your-pagerduty-routing-key

# -- Grafana --
GRAFANA_ADMIN_PASSWORD=admin

# -- AWS (for S3 backups, if running outside AWS) --
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BACKUP_BUCKET=driftwatch-backups
