# Set to the full backend URL when not using Vercel rewrites.
# When deployed on Vercel with rewrites, leave as /api.
VITE_API_URL=/api

# Optional demo-only auto-login for local development or preview environments.
# Keep this disabled in production.
# VITE_ENABLE_DEMO_AUTO_LOGIN=true
# VITE_DEMO_EMAIL=smoke@test.io
# VITE_DEMO_PASSWORD=smoke1234
# VITE_DEMO_ORG=Smoke Test Org
